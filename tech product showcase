<script>
// ===== PAGE NAVIGATION =====
function showPage(page) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.getElementById('page-' + page).classList.add('active');
    window.scrollTo(0, 0);
}

// ===== CART STATE =====
let cart = [];

function getTotal() {
    return cart.reduce((s, i) => s + i.price * i.qty, 0);
}

function formatRp(n) {
    return 'Rp ' + n.toLocaleString('id-ID');
}

function updateCartUI() {
    const itemsEl = document.getElementById('cartItems');
    const emptyEl = document.getElementById('cartEmpty');
    const footerEl = document.getElementById('cartFooter');
    const badgeEl = document.getElementById('cartBadge');

    const totalQty = cart.reduce((s, i) => s + i.qty, 0);
    badgeEl.textContent = totalQty;
    badgeEl.classList.toggle('show', totalQty > 0);

    if (cart.length === 0) {
        emptyEl.style.display = 'block';
        footerEl.style.display = 'none';
        // Remove all cart items except empty
        itemsEl.querySelectorAll('.cart-item').forEach(el => el.remove());
        return;
    }

    emptyEl.style.display = 'none';
    footerEl.style.display = 'block';

    // Rebuild list
    itemsEl.querySelectorAll('.cart-item').forEach(el => el.remove());
    cart.forEach((item, idx) => {
        const div = document.createElement('div');
        div.className = 'cart-item';
        div.innerHTML = `
            <div class="cart-item-img">
                <img src="${item.img}" alt="${item.name}">
            </div>
            <div class="cart-item-info">
                <h4>${item.name}</h4>
                <div class="cart-item-cat">${item.cat}</div>
                <div class="cart-item-actions">
                    <div class="qty-control">
                        <button class="qty-btn" onclick="changeQty(${idx}, -1)">−</button>
                        <span class="qty-val">${item.qty}</span>
                        <button class="qty-btn" onclick="changeQty(${idx}, 1)">+</button>
                    </div>
                    <span class="cart-item-price">${formatRp(item.price * item.qty)}</span>
                    <button class="cart-item-remove" onclick="removeItem(${idx})">🗑</button>
                </div>
            </div>
        `;
        itemsEl.appendChild(div);
    });

    const subtotal = getTotal();
    const shipping = 35000;
    document.getElementById('cartSubtotal').textContent = formatRp(subtotal);
    document.getElementById('cartTotal').textContent = formatRp(subtotal + shipping);
}

function addToCart(name, price, cat, img) {
    const existing = cart.find(i => i.name === name);
    if (existing) {
        existing.qty++;
    } else {
        cart.push({ name, price, cat, img, qty: 1 });
    }
    updateCartUI();
    showToast('Ditambahkan! 🛒', `${name} masuk ke keranjang.`);
}

function changeQty(idx, delta) {
    cart[idx].qty += delta;
    if (cart[idx].qty <= 0) cart.splice(idx, 1);
    updateCartUI();
}

function removeItem(idx) {
    cart.splice(idx, 1);
    updateCartUI();
}

// ===== CART TOGGLE =====
function toggleCart() {
    document.getElementById('cartSidebar').classList.toggle('show');
    document.getElementById('cartOverlay').classList.toggle('show');
}

// ===== CHECKOUT =====
function openCheckout() {
    if (cart.length === 0) return;
    toggleCart();
    buildCheckoutSummary();
    document.getElementById('checkoutModal').classList.add('show');
}

function closeCheckout() {
    document.getElementById('checkoutModal').classList.remove('show');
}

function buildCheckoutSummary() {
    const el = document.getElementById('checkoutSummary');
    let html = '';
    cart.forEach(item => {
        html += `<div class="checkout-order-item"><span>${item.name} x${item.qty}</span><span>${formatRp(item.price * item.qty)}</span></div>`;
    });
    const subtotal = getTotal();
    html += `<div class="checkout-order-item"><span>Ongkos Kirim</span><span>Rp 35.000</span></div>`;
    html += `<div class="checkout-order-total"><span>Total Pembayaran</span><span class="total-price">${formatRp(subtotal + 35000)}</span></div>`;
    el.innerHTML = html;
}

function processPayment() {
    const name = document.getElementById('ch-name').value.trim();
    const phone = document.getElementById('ch-phone').value.trim();
    const address = document.getElementById('ch-address').value.trim();

    if (!name || !phone || !address) {
        showToast('⚠️ Lengkapi Data', 'Isi nama, telepon, dan alamat dulu ya!');
        return;
    }

    closeCheckout();
    const orderId = '#SZ-' + Math.floor(100000 + Math.random() * 900000);
    document.getElementById('orderId').textContent = orderId;
    document.getElementById('successModal').classList.add('show');
}

function closeSuccess() {
    const orderId = document.getElementById('orderId').textContent;
    document.getElementById('successModal').classList.remove('show');
    cart = [];
    updateCartUI();
    ['ch-name','ch-phone','ch-address','ch-city','ch-zip'].forEach(id => {
        const el = document.getElementById(id);
        if (el) el.value = '';
    });
    const msg = encodeURIComponent(
        'Halo SoundZ! \n\nSaya baru saja melakukan pembelian dengan nomor pesanan: ' + orderId + '\n\nMohon konfirmasinya ya. Terima kasih!'
    );
    window.open('https://wa.me/6282114822845?text=' + msg, '_blank');
}

// ===== CONTACT =====
function submitContact() {
    const name = document.getElementById('c-name').value.trim();
    const email = document.getElementById('c-email').value.trim();
    const msg = document.getElementById('c-msg').value.trim();

    if (!name || !email || !msg) {
        showToast('⚠️ Lengkapi Form', 'Nama, email, dan pesan wajib diisi.');
        return;
    }

    showToast('✅ Pesan Terkirim!', 'Tim kami akan menghubungi Anda segera.');
    ['c-name','c-email','c-phone','c-msg'].forEach(id => {
        document.getElementById(id).value = '';
    });
    document.getElementById('c-topic').selectedIndex = 0;
}

// ===== TOAST =====
let toastTimer;
function showToast(title, msg) {
    document.getElementById('toastTitle').textContent = title;
    document.getElementById('toastMsg').textContent = msg;
    const el = document.getElementById('toast');
    el.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(() => el.classList.remove('show'), 3000);
}

// ===== CAROUSEL LOGIC =====
let nextButton = document.getElementById('next');
let prevButton = document.getElementById('prev');
let carousel = document.getElementById('carousel');
let listHTML = document.querySelector('.carousel .list');
let backButton = document.getElementById('back');
let unAcceptClick;

const showSlider = (type) => {
    nextButton.style.pointerEvents = 'none';
    prevButton.style.pointerEvents = 'none';
    carousel.classList.remove('next', 'prev');
    let items = document.querySelectorAll('.carousel .list .item');
    if (type === 'next') {
        listHTML.appendChild(items[0]);
        carousel.classList.add('next');
    } else {
        listHTML.prepend(items[items.length - 1]);
        carousel.classList.add('prev');
    }
    clearTimeout(unAcceptClick);
    unAcceptClick = setTimeout(() => {
        nextButton.style.pointerEvents = 'auto';
        prevButton.style.pointerEvents = 'auto';
    }, 2000);
    rebindButtons();
};

nextButton.onclick = () => showSlider('next');
prevButton.onclick = () => showSlider('prev');
backButton.onclick = () => carousel.classList.remove('showDetail');

function rebindButtons() {
    setTimeout(() => {
        // Re-bind seeMore
        document.querySelectorAll('.seeMore').forEach(btn => {
            btn.onclick = function () {
                carousel.classList.remove('next', 'prev');
                carousel.classList.add('showDetail');
            };
        });
        // Re-bind add to cart & checkout
        bindProductButtons();
    }, 100);
}

function bindProductButtons() {
    document.querySelectorAll('.btn-add-cart').forEach(btn => {
        btn.onclick = function () {
            const item = btn.closest('.item');
            const name = item.dataset.name;
            const price = parseInt(item.dataset.price);
            const cat = item.dataset.cat;
            const img = item.querySelector('img').src;
            addToCart(name, price, cat, img);
        };
    });

    document.querySelectorAll('.btn-checkout-main-trigger').forEach(btn => {
        btn.onclick = function () {
            const item = btn.closest('.item');
            const name = item.dataset.name;
            const price = parseInt(item.dataset.price);
            const cat = item.dataset.cat;
            const img = item.querySelector('img').src;
            // Add if not in cart
            const existing = cart.find(i => i.name === name);
            if (!existing) addToCart(name, price, cat, img);
            setTimeout(openCheckout, 200);
        };
    });
}

document.querySelectorAll('.seeMore').forEach(btn => {
    btn.onclick = function () {
        carousel.classList.remove('next', 'prev');
        carousel.classList.add('showDetail');
    };
});

bindProductButtons();
</script>
</body>
</html>
