        function startReload() {
            if (isReloading || ammo >= magazineSize || totalAmmo <= 0) return;
            
            isReloading = true;
            document.getElementById('reload-indicator').style.display = 'block';
            gunMesh.rotation.x = 0.5;
            
            setTimeout(() => {
                const needed = magazineSize - ammo;
                const available = Math.min(needed, totalAmmo);
                ammo += available;
                totalAmmo -= available;
                
                isReloading = false;
                gunMesh.rotation.x = 0;
                document.getElementById('reload-indicator').style.display = 'none';
                updateAmmoDisplay();
            }, 2500);
        }
        
        function updateAmmoDisplay() {
