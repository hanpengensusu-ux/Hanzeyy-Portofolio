        function addKillFeed(message) {
            const feed = document.getElementById('kill-feed');
            const msg = document.createElement('div');
            msg.className = 'kill-message';
            msg.textContent = message;
            msg.style.color = message.includes('HEADSHOT') ? '#ff0' : '#fff';
            feed.appendChild(msg);
            setTimeout(() => msg.remove(), 3000);
        }
        
        function updateMinimap() {
            const canvas = document.getElementById('minimap-canvas');
            const ctx = canvas.getContext('2d');
            canvas.width = 150;
            canvas.height = 150;
            
            ctx.fillStyle = 'rgba(20, 40, 20, 0.8)';
            ctx.fillRect(0, 0, 150, 150);
            
            const scale = 150 / (mapSize * 2);
            const offsetX = 75;
            const offsetZ = 75;
            
            ctx.fillStyle = '#555';
            walls.forEach(wall => {
                const x = wall.position.x * scale + offsetX;
                const z = wall.position.z * scale + offsetZ;
                const w = wall.geometry.parameters.width * scale;
                const d = wall.geometry.parameters.depth * scale;
                ctx.fillRect(x - w/2, z - d/2, w, d);
            });
            
            enemies.forEach(enemy => {
                if (!enemy.isDead) {
                    const x = enemy.mesh.position.x * scale + offsetX;
                    const z = enemy.mesh.position.z * scale + offsetZ;
                    ctx.fillStyle = '#ff0000';
                    ctx.beginPath();
                    ctx.arc(x, z, 3, 0, Math.PI * 2);
                    ctx.fill();
                }
            });
            
            const px = player.position.x * scale + offsetX;
            const pz = player.position.z * scale + offsetZ;
            ctx.fillStyle = '#00ff00';
            ctx.beginPath();
            ctx.arc(px, pz, 4, 0, Math.PI * 2);
            ctx.fill();
            
            const direction = new THREE.Vector3();
            camera.getWorldDirection(direction);
            ctx.strokeStyle = '#00ff00';
            ctx.lineWidth = 2;
            ctx.beginPath();
            ctx.moveTo(px, pz);
            ctx.lineTo(px + direction.x * 15, pz + direction.z * 15);
            ctx.stroke();
        }
        
        function checkWallCollision(position, radius) {
            for (let wall of walls) {
                const wallPos = wall.position;
                const wallGeo = wall.geometry.parameters;
                const halfW = wallGeo.width / 2 + radius;
                const halfD = wallGeo.depth / 2 + radius;
                
                if (position.x > wallPos.x - halfW && position.x < wallPos.x + halfW &&
                    position.z > wallPos.z - halfD && position.z < wallPos.z + halfD) {
                    return true;
                }
            }
            return false;
        }
        
        function updatePlayer(delta) {
            if (gameState !== 'playing') return;
            
            playerVelocity.y -= gravity * delta;
            
            let speed = walkSpeed;
            if (isSprinting) speed = sprintSpeed;
            if (isCrouching) speed = crouchSpeed;
            
            playerDirection.set(0, 0, 0);
            if (moveForward) playerDirection.z -= 1;
            if (moveBackward) playerDirection.z += 1;
            if (moveLeft) playerDirection.x -= 1;
            if (moveRight) playerDirection.x += 1;
            
            if (playerDirection.length() > 0) {
                playerDirection.normalize();
                
                const cameraDirection = new THREE.Vector3();
                camera.getWorldDirection(cameraDirection);
                cameraDirection.y = 0;
                cameraDirection.normalize();
                
                const cameraRight = new THREE.Vector3();
                cameraRight.crossVectors(cameraDirection, new THREE.Vector3(0, 1, 0));
                
                const moveVector = new THREE.Vector3()
                    .addScaledVector(cameraDirection, -playerDirection.z)
                    .addScaledVector(cameraRight, playerDirection.x);
                
                moveVector.normalize().multiplyScalar(speed * delta);
                
                const nextPos = player.position.clone().add(moveVector);
                if (!checkWallCollision(nextPos, 0.5)) {
                    player.position.x = nextPos.x;
                    player.position.z = nextPos.z;
                }
                
                if (weaponGroup) {
                    const swayAmount = 0.02;
                    weaponGroup.position.x = 0.3 + Math.sin(Date.now() * 0.01) * swayAmount;
                    weaponGroup.rotation.z = Math.sin(Date.now() * 0.008) * swayAmount * 2;
                }
            } else {
                if (weaponGroup) {
                    weaponGroup.position.x += (0.3 - weaponGroup.position.x) * 0.1;
                    weaponGroup.rotation.z *= 0.9;
                }
            }
            
            player.position.y += playerVelocity.y * delta;
            
            if (player.position.y < (isCrouching ? 1.0 : 1.7)) {
                player.position.y = isCrouching ? 1.0 : 1.7;
                playerVelocity.y = 0;
                canJump = true;
            }
            
            player.position.x = THREE.MathUtils.clamp(player.position.x, -mapSize + 2, mapSize - 2);
            player.position.z = THREE.MathUtils.clamp(player.position.z, -mapSize + 2, mapSize - 2);
        }
        
        function setupEventListeners() {
            document.addEventListener('click', () => {
                if (gameState === 'playing' && !isPointerLocked) {
                    document.body.requestPointerLock();
                }
            });
            
            document.addEventListener('pointerlockchange', () => {
                isPointerLocked = document.pointerLockElement === document.body;
            });
            
            document.addEventListener('mousemove', (event) => {
                if (!isPointerLocked || gameState !== 'playing') return;
                
                const sensitivity = 0.002;
                camera.rotation.y -= event.movementX * sensitivity;
                camera.rotation.x -= event.movementY * sensitivity;
                camera.rotation.x = THREE.MathUtils.clamp(camera.rotation.x, -Math.PI / 2, Math.PI / 2);
            });
            
            document.addEventListener('keydown', (event) => {
                switch (event.code) {
                    case 'KeyW': moveForward = true; break;
                    case 'KeyS': moveBackward = true; break;
                    case 'KeyA': moveLeft = true; break;
                    case 'KeyD': moveRight = true; break;
                    case 'Space':
                        if (canJump && !isCrouching) {
                            playerVelocity.y = jumpHeight;
                            canJump = false;
                        }
                        break;
                    case 'ShiftLeft': isSprinting = true; break;
                    case 'KeyC': isCrouching = true; break;
                    case 'KeyR': startReload(); break;
                }
            });
            
            document.addEventListener('keyup', (event) => {
                switch (event.code) {
                    case 'KeyW': moveForward = false; break;
                    case 'KeyS': moveBackward = false; break;
                    case 'KeyA': moveLeft = false; break;
                    case 'KeyD': moveRight = false; break;
                    case 'ShiftLeft': isSprinting = false; break;
                    case 'KeyC': isCrouching = false; break;
                }
            });
            
            document.addEventListener('mousedown', (event) => {
                if (event.button === 0 && gameState === 'playing') {
                    playerShoot();
                }
            });
            
            document.getElementById('start-btn').addEventListener('click', () => {
                document.getElementById('start-screen').style.display = 'none';
                gameState = 'playing';
                document.body.requestPointerLock();
            });
            
            document.getElementById('restart-btn').addEventListener('click', restartGame);
            
            window.addEventListener('resize', () => {
                camera.aspect = window.innerWidth / window.innerHeight;
                camera.updateProjectionMatrix();
                renderer.setSize(window.innerWidth, window.innerHeight);
            });
        }
        
        let lastTime = 0;
        
        function animate(time) {
            requestAnimationFrame(animate);
            
            const delta = Math.min((time - lastTime) / 1000, 0.1);
            lastTime = time;
            
            if (gameState === 'playing') {
                updatePlayer(delta);
                updateEnemies(delta);
                updateBullets(delta);
                updateParticles(delta);
                updateMinimap();
                
                if (camera.rotation.x < 0) {
                    camera.rotation.x += delta * 2;
                    if (camera.rotation.x > 0) camera.rotation.x = 0;
                }
            }
            
            renderer.render(scene, camera);
        }
        
