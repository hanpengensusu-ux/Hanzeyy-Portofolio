        function spawnEnemies(count) {
            for (let i = 0; i < count; i++) {
                const enemy = createHumanEnemy();
                let x, z;
                do {
                    x = (Math.random() - 0.5) * mapSize * 1.5;
                    z = (Math.random() - 0.5) * mapSize * 1.5;
                } while (Math.abs(x) < 15 && Math.abs(z) < 15);
                
                enemy.mesh.position.set(x, 0, z);
                enemy.groundY = 0;
                enemy.patrolTarget.set(
                    (Math.random() - 0.5) * mapSize * 1.5,
                    0,
                    (Math.random() - 0.5) * mapSize * 1.5
                );
                
                scene.add(enemy.mesh);
                enemies.push(enemy);
            }
        }
        
        function updateEnemies(delta) {
            const now = Date.now() / 1000;
            
            enemies.forEach(enemy => {
                if (enemy.isDead) return;
                
                enemy.animTime += delta;
                
                // Health bar face camera
                enemy.healthBar.lookAt(camera.position);
                enemy.healthBarBg.lookAt(camera.position);
                
                const distToPlayer = enemy.mesh.position.distanceTo(player.position);
                
                // AI State
                if (distToPlayer < 4) {
                    enemy.state = 'attack';
                } else if (distToPlayer < 30) {
                    enemy.state = 'chase';
                } else {
                    enemy.state = 'patrol';
                }
                
                let targetPos = new THREE.Vector3();
                let moveSpeed = enemy.speed;
                
                switch (enemy.state) {
                    case 'patrol':
                        targetPos.copy(enemy.patrolTarget);
                        if (enemy.mesh.position.distanceTo(enemy.patrolTarget) < 2) {
                            enemy.patrolTarget.set(
                                (Math.random() - 0.5) * mapSize * 1.5,
                                0,
                                (Math.random() - 0.5) * mapSize * 1.5
                            );
                        }
                        break;
                    case 'chase':
                        targetPos.copy(player.position);
                        targetPos.y = enemy.groundY;
                        break;
                    case 'attack':
                        const angle = now + enemy.animTime * 0.5;
                        targetPos.set(
                            player.position.x + Math.cos(angle) * 6,
                            enemy.groundY,
                            player.position.z + Math.sin(angle) * 6
                        );
                        moveSpeed = enemy.speed * 1.3;
                        break;
                }
                
                // Move enemy
                const direction = new THREE.Vector3().subVectors(targetPos, enemy.mesh.position);
                direction.y = 0;
                
                if (direction.length() > 0.1) {
                    direction.normalize();
                    const nextPos = enemy.mesh.position.clone();
                    nextPos.x += direction.x * moveSpeed * delta;
                    nextPos.z += direction.z * moveSpeed * delta;
                    
                    if (!checkWallCollision(nextPos, 0.5)) {
                        enemy.mesh.position.x = nextPos.x;
                        enemy.mesh.position.z = nextPos.z;
                    }
                }
                
                // FIX: MUSUH TIDAK IKUT PLAYER KE ATAS
                enemy.mesh.position.y = enemy.groundY;
                
                // Look at player
                const lookTarget = new THREE.Vector3(
                    player.position.x,
                    enemy.mesh.position.y + 1.7,
                    player.position.z
                );
                enemy.mesh.lookAt(lookTarget);
                
                // Walking animation
                const walkCycle = Math.sin(enemy.animTime * 6) * 0.15;
                enemy.leftLeg.rotation.x = walkCycle;
                enemy.rightLeg.rotation.x = -walkCycle;
                enemy.leftArm.rotation.x = -walkCycle * 0.5;
                enemy.rightArm.rotation.x = walkCycle * 0.5;
                
                // Bobbing when walking
                enemy.mesh.position.y = enemy.groundY + Math.abs(Math.sin(enemy.animTime * 6)) * 0.05;
                
                // Gun aim at player
                enemy.gun.lookAt(player.position.x, player.position.y, player.position.z);
                
                // Shooting
                if ((enemy.state === 'attack' || (enemy.state === 'chase' && distToPlayer < 20)) && distToPlayer < 40) {
                    if (now - enemy.lastShot > enemy.shotInterval) {
                        enemyShoot(enemy);
                        enemy.lastShot = now;
                    }
                }
            });
        }
        
        function enemyShoot(enemy) {
            const bulletGeo = new THREE.SphereGeometry(0.08, 8, 8);
            const bulletMat = new THREE.MeshBasicMaterial({ color: 0xff6600 });
            const bullet = new THREE.Mesh(bulletGeo, bulletMat);
            
            const gunPos = new THREE.Vector3();
            enemy.gun.getWorldPosition(gunPos);
            bullet.position.copy(gunPos);
            
            const direction = new THREE.Vector3().subVectors(player.position, gunPos);
            direction.y += (Math.random() - 0.5) * 0.8;
            direction.x += (Math.random() - 0.5) * 0.5;
            direction.normalize();
            
            bullet.userData = {
                velocity: direction.multiplyScalar(25),
                damage: 8,
                life: 3,
                owner: 'enemy'
            };
            
            scene.add(bullet);
            enemyBullets.push(bullet);
            
            const flash = new THREE.PointLight(0xffaa00, 3, 8);
            flash.position.copy(gunPos);
            scene.add(flash);
            setTimeout(() => scene.remove(flash), 60);
            
            enemy.gun.rotation.x -= 0.15;
            setTimeout(() => { enemy.gun.rotation.x += 0.15; }, 100);
        }
        
        function playerShoot() {
            if (isReloading || ammo <= 0) {
                if (ammo <= 0 && !isReloading) startReload();
                return;
            }
            
            ammo--;
            updateAmmoDisplay();
            
            // Weapon recoil animation
            gunMesh.position.z += 0.1;
            gunMesh.rotation.x -= 0.1;
            rightArm.rotation.x -= 0.1;
            leftArm.rotation.x -= 0.05;
            
            setTimeout(() => {
                gunMesh.position.z -= 0.1;
                gunMesh.rotation.x += 0.1;
                rightArm.rotation.x += 0.1;
                leftArm.rotation.x += 0.05;
            }, 80);
            
            // Get camera direction
            const direction = new THREE.Vector3();
            camera.getWorldDirection(direction);
            
            // Add bullet spread
            direction.x += (Math.random() - 0.5) * 0.02;
            direction.y += (Math.random() - 0.5) * 0.02;
            direction.normalize();
            
            // Visual bullet
            const gunWorldPos = new THREE.Vector3();
            gunMesh.getWorldPosition(gunWorldPos);
            
            const bulletGeo = new THREE.SphereGeometry(0.06, 8, 8);
            const bulletMat = new THREE.MeshBasicMaterial({ color: 0xffff00 });
            const bullet = new THREE.Mesh(bulletGeo, bulletMat);
            bullet.position.copy(gunWorldPos);
            bullet.userData = {
                velocity: direction.clone().multiplyScalar(60),
                damage: 34,
                life: 2,
                owner: 'player'
            };
            scene.add(bullet);
            bullets.push(bullet);
            
            // Camera recoil
            camera.rotation.x -= 0.015;
            
            // Muzzle flash
            const flash = new THREE.PointLight(0xffaa00, 4, 10);
            flash.position.copy(gunWorldPos);
            scene.add(flash);
            setTimeout(() => scene.remove(flash), 50);
            
            // AUTO AIM HIT DETECTION - Tembak langsung kena musuh yang di crosshair
            checkBulletHit(camera.position, direction);
        }
        
        function checkBulletHit(startPos, direction) {
            // Raycaster dari tengah layar (crosshair)
            const raycaster = new THREE.Raycaster(startPos, direction.clone().normalize(), 0, 200);
            
            // Kumpulkan SEMUA mesh dari SEMUA musuh
            let allEnemyMeshes = [];
            for (let enemy of enemies) {
                if (enemy.isDead) continue;
                enemy.mesh.traverse((child) => {
                    if (child.isMesh) {
                        child.userData.parentEnemy = enemy;
                        allEnemyMeshes.push(child);
                    }
                });
            }
            
            // Cek intersection dengan semua mesh musuh
            const intersects = raycaster.intersectObjects(allEnemyMeshes, false);
            
            if (intersects.length > 0) {
                const hit = intersects[0];
                const hitEnemy = hit.object.userData.parentEnemy;
                
                if (!hitEnemy || hitEnemy.isDead) return;
                
                // Hit point world position
                const hitPoint = hit.point;
                
                // Cek headshot berdasarkan tinggi hit
                const enemyHeadHeight = hitEnemy.mesh.position.y + 1.6;
                const isHeadshot = hitPoint.y > enemyHeadHeight;
                
                const damage = isHeadshot ? 100 : 34;
                
                // Kurangi health musuh
                hitEnemy.health -= damage;
                const healthPercent = Math.max(0, hitEnemy.health / hitEnemy.maxHealth);
                hitEnemy.healthBar.scale.x = healthPercent;
                
                // Tampilkan hit marker
                showHitMarker();
                
                // Blood particles
                createBloodParticles(hitPoint);
                
                // Kill feed
                if (isHeadshot) {
                    addKillFeed("HEADSHOT! +" + damage);
                } else {
                    addKillFeed("Hit! +" + damage);
                }
                
                // Cek musuh mati
                if (hitEnemy.health <= 0) {
                    killEnemy(hitEnemy);
                }
            }
        }
        
        function killEnemy(enemy) {
            enemy.isDead = true;
            enemy.mesh.rotation.x = -Math.PI / 2;
            enemy.mesh.position.y = 0.3;
            enemy.healthBar.visible = false;
            enemy.healthBarBg.visible = false;
            
            teamScore++;
            kills++;
            updateScoreboard();
            addKillFeed("Anda membunuh musuh!");
            
            // Blood pool di tanah
            const bloodGeo = new THREE.CircleGeometry(1, 16);
            const bloodMat = new THREE.MeshBasicMaterial({ color: 0x8B0000, transparent: true, opacity: 0.6 });
            const blood = new THREE.Mesh(bloodGeo, bloodMat);
            blood.rotation.x = -Math.PI / 2;
            blood.position.set(enemy.mesh.position.x, 0.02, enemy.mesh.position.z);
            scene.add(blood);
            
            setTimeout(() => {
                scene.remove(blood);
                respawnEnemy(enemy);
            }, 6000);
        }
        
        function respawnEnemy(enemy) {
            enemy.isDead = false;
            enemy.health = enemy.maxHealth;
            enemy.mesh.rotation.x = 0;
            enemy.healthBar.visible = true;
            enemy.healthBarBg.visible = true;
            enemy.healthBar.scale.x = 1;
            
            let x, z;
            do {
                x = (Math.random() - 0.5) * mapSize * 1.5;
                z = (Math.random() - 0.5) * mapSize * 1.5;
            } while (Math.abs(x) < 15 && Math.abs(z) < 15);
            
            enemy.mesh.position.set(x, 0, z);
            enemy.groundY = 0;
        }
        
        function updateBullets(delta) {
            for (let i = bullets.length - 1; i >= 0; i--) {
                const bullet = bullets[i];
                bullet.position.add(bullet.userData.velocity.clone().multiplyScalar(delta));
                bullet.userData.life -= delta;
                
                if (bullet.userData.life <= 0) {
                    scene.remove(bullet);
                    bullets.splice(i, 1);
                }
            }
            
            for (let i = enemyBullets.length - 1; i >= 0; i--) {
                const bullet = enemyBullets[i];
                bullet.position.add(bullet.userData.velocity.clone().multiplyScalar(delta));
                bullet.userData.life -= delta;
                
                if (bullet.position.distanceTo(player.position) < 1.2) {
                    takeDamage(bullet.userData.damage);
                    scene.remove(bullet);
                    enemyBullets.splice(i, 1);
                    continue;
                }
                
                if (bullet.userData.life <= 0) {
                    scene.remove(bullet);
                    enemyBullets.splice(i, 1);
                }
            }
        }
        
        function createBloodParticles(position) {
            for (let i = 0; i < 12; i++) {
                const particleGeo = new THREE.BoxGeometry(0.04, 0.04, 0.04);
                const particleMat = new THREE.MeshBasicMaterial({ color: 0x8B0000 });
                const particle = new THREE.Mesh(particleGeo, particleMat);
                
                particle.position.copy(position);
                particle.userData = {
                    velocity: new THREE.Vector3(
                        (Math.random() - 0.5) * 6,
                        Math.random() * 6 + 2,
                        (Math.random() - 0.5) * 6
                    ),
                    life: 1.5
                };
                
                scene.add(particle);
                particles.push(particle);
            }
        }
        
        function updateParticles(delta) {
            for (let i = particles.length - 1; i >= 0; i--) {
                const particle = particles[i];
                particle.position.add(particle.userData.velocity.clone().multiplyScalar(delta));
                particle.userData.velocity.y -= gravity * delta;
                particle.userData.life -= delta;
                
                if (particle.userData.life <= 0 || particle.position.y < 0) {
                    scene.remove(particle);
                    particles.splice(i, 1);
                }
            }
        }
        
        function takeDamage(damage) {
            health -= damage;
            health = Math.max(0, health);
            
            const healthPercent = health / maxHealth;
            document.getElementById('health-bar').style.width = (healthPercent * 100) + '%';
            document.getElementById('health-text').textContent = health + ' / ' + maxHealth;
            
            const overlay = document.getElementById('damage-overlay');
            overlay.style.opacity = '1';
            setTimeout(() => overlay.style.opacity = '0', 200);
            
            camera.position.x += (Math.random() - 0.5) * 0.3;
            camera.position.y += (Math.random() - 0.5) * 0.3;
            
            if (health <= 0) {
                enemyScore++;
                updateScoreboard();
                gameOver();
