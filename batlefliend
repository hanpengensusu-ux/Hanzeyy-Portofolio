        const gravity = 30, jumpHeight = 10;
        const walkSpeed = 8, sprintSpeed = 14, crouchSpeed = 4;
        const mapSize = 80, wallHeight = 6;
        
        function init() {
            scene = new THREE.Scene();
            scene.background = new THREE.Color(0x87CEEB);
            scene.fog = new THREE.Fog(0x87CEEB, 20, 180);
            
            camera = new THREE.PerspectiveCamera(75, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.set(0, 1.7, 0);
            
            renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            renderer.shadowMap.enabled = true;
            renderer.shadowMap.type = THREE.PCFSoftShadowMap;
            renderer.setPixelRatio(window.devicePixelRatio);
            document.body.appendChild(renderer.domElement);
            renderer.domElement.id = 'gameCanvas';
            
            setupLighting();
            createMap();
            createWeaponModel();
            
            player = new THREE.Object3D();
            player.position.set(0, 1.7, 0);
            player.add(camera);
            scene.add(player);
            
            playerVelocity = new THREE.Vector3();
            playerDirection = new THREE.Vector3();
            
            spawnEnemies(6);
            setupEventListeners();
            animate();
        }
        
        function setupLighting() {
            const ambientLight = new THREE.AmbientLight(0x404040, 0.5);
            scene.add(ambientLight);
            
            const directionalLight = new THREE.DirectionalLight(0xffffff, 1.2);
            directionalLight.position.set(50, 100, 50);
            directionalLight.castShadow = true;
            directionalLight.shadow.mapSize.width = 2048;
            directionalLight.shadow.mapSize.height = 2048;
            directionalLight.shadow.camera.near = 0.5;
            directionalLight.shadow.camera.far = 500;
            directionalLight.shadow.camera.left = -100;
            directionalLight.shadow.camera.right = 100;
            directionalLight.shadow.camera.top = 100;
            directionalLight.shadow.camera.bottom = -100;
            scene.add(directionalLight);
            
            const hemiLight = new THREE.HemisphereLight(0x87CEEB, 0x3d3d3d, 0.6);
            scene.add(hemiLight);
        }
        
        function createMap() {
            const groundGeometry = new THREE.PlaneGeometry(mapSize * 2, mapSize * 2, 50, 50);
            const groundMaterial = new THREE.MeshStandardMaterial({ 
                color: 0x6B8E23, roughness: 0.9, metalness: 0.1
            });
            const ground = new THREE.Mesh(groundGeometry, groundMaterial);
            ground.rotation.x = -Math.PI / 2;
            ground.receiveShadow = true;
            scene.add(ground);
            
            const positions = ground.geometry.attributes.position;
            for (let i = 0; i < positions.count; i++) {
                positions.setY(i, Math.random() * 0.3);
            }
            positions.needsUpdate = true;
            ground.geometry.computeVertexNormals();
            
            const gridHelper = new THREE.GridHelper(mapSize * 2, 40, 0x444444, 0x333333);
            gridHelper.position.y = 0.02;
            scene.add(gridHelper);
            
            createWalls();
            createCoverObjects();
            createEnvironment();
        }
        
        function createWalls() {
            const wallMaterial = new THREE.MeshStandardMaterial({ color: 0x808080, roughness: 0.9, metalness: 0.1 });
            const wallThickness = 2;
            
            const positions = [
                { x: 0, z: -mapSize, w: mapSize * 2, h: wallHeight, d: wallThickness },
                { x: 0, z: mapSize, w: mapSize * 2, h: wallHeight, d: wallThickness },
                { x: -mapSize, z: 0, w: wallThickness, h: wallHeight, d: mapSize * 2 },
                { x: mapSize, z: 0, w: wallThickness, h: wallHeight, d: mapSize * 2 }
            ];
            
            positions.forEach(pos => {
                const geometry = new THREE.BoxGeometry(pos.w, pos.h, pos.d);
                const wall = new THREE.Mesh(geometry, wallMaterial);
                wall.position.set(pos.x, pos.h / 2, pos.z);
                wall.castShadow = true;
                wall.receiveShadow = true;
                scene.add(wall);
                walls.push(wall);
            });
            
            const buildingPositions = [
                { x: -25, z: -25, w: 12, h: 8, d: 12 },
                { x: 25, z: -25, w: 10, h: 6, d: 15 },
                { x: -25, z: 25, w: 15, h: 10, d: 10 },
                { x: 25, z: 25, w: 12, h: 7, d: 12 },
                { x: 0, z: -40, w: 20, h: 5, d: 6 },
                { x: 0, z: 40, w: 18, h: 6, d: 8 },
                { x: -40, z: 0, w: 6, h: 4, d: 15 },
                { x: 40, z: 0, w: 8, h: 5, d: 18 },
                { x: -15, z: -40, w: 8, h: 3, d: 8 },
                { x: 15, z: 40, w: 10, h: 4, d: 6 }
            ];
            
            buildingPositions.forEach(pos => {
                const geometry = new THREE.BoxGeometry(pos.w, pos.h, pos.d);
                const building = new THREE.Mesh(geometry, wallMaterial);
                building.position.set(pos.x, pos.h / 2, pos.z);
                building.castShadow = true;
                building.receiveShadow = true;
                scene.add(building);
                walls.push(building);
            });
        }
        
        function createCoverObjects() {
            const barrelGeometry = new THREE.CylinderGeometry(0.4, 0.4, 1.4, 16);
            const barrelMaterial = new THREE.MeshStandardMaterial({ color: 0x8B4513, roughness: 0.7 });
            
            for (let i = 0; i < 20; i++) {
                const barrel = new THREE.Mesh(barrelGeometry, barrelMaterial);
                barrel.position.set(
                    (Math.random() - 0.5) * mapSize * 1.5,
                    0.7,
                    (Math.random() - 0.5) * mapSize * 1.5
                );
                barrel.castShadow = true;
                barrel.receiveShadow = true;
                scene.add(barrel);
